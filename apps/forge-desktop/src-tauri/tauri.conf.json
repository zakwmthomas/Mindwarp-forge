{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mind Warp Forge",
  "version": "0.1.0",
  "identifier": "com.mindwarp.forge",
  "build": {
    "beforeBuildCommand": "npm.cmd run build --prefix ui",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mind Warp Forge",
        "width": 1100,
        "height": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all"
  }
}
