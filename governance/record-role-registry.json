{
  "schema_version": 1,
  "purpose": "Ordered classification rules ensuring every durable Forge path has one declared responsibility.",
  "ignored_roots": [".git", ".local", "target", "node_modules", "dist", "local-data", "exports"],
  "rules": [
    {"pattern":"context/active/CURRENT_STATE.md","role":"generated_projection"},
    {"pattern":"context/bootstrap/BRIEFING.md","role":"generated_projection"},
    {"pattern":"governance/WORKER_FEEDBACK_BRIEF.md","role":"generated_projection"},
    {"pattern":"docs/project-atlas/MASTER_PLAN.md","role":"generated_projection"},
    {"pattern":"apps/forge-desktop/src-tauri/gen/**","role":"generated_projection"},
    {"pattern":"artifacts/chat-screenshots/**","role":"ephemeral_presentation_artifact"},
    {"pattern":"context/active/WORKER_WAKE_LOG.jsonl","role":"append_only_evidence"},
    {"pattern":"context/active/WORKER_BATCH_STATE.json","role":"canonical_checkpoint"},
    {"pattern":"docs/canonical-system/MASTER_PROGRAM.json","role":"canonical_execution_registry"},
    {"pattern":"governance/policy-registry.json","role":"canonical_policy_registry"},
    {"pattern":"governance/record-role-registry.json","role":"canonical_path_role_registry"},
    {"pattern":"evidence/**","role":"immutable_evidence"},
    {"pattern":"contracts/**","role":"canonical_contract"},
    {"pattern":"crates/**","role":"implementation_and_tests"},
    {"pattern":"apps/**","role":"implementation_and_tests"},
    {"pattern":"tools/**","role":"verification_and_operations"},
    {"pattern":"governance/**","role":"governance_record"},
    {"pattern":"docs/canonical-system/**","role":"canonical_system_record"},
    {"pattern":"docs/project-atlas/**","role":"navigation_projection"},
    {"pattern":"docs/**","role":"design_or_research_record"},
    {"pattern":"context/capsules/**","role":"context_evidence"},
    {"pattern":"context/**","role":"context_navigation"},
    {"pattern":"handover/**","role":"recovered_source_evidence"},
    {"pattern":"forge documents from gpt handover/**","role":"recovered_source_evidence"},
    {"pattern":"AGENTS.md","role":"task_bootstrap_authority"},
    {"pattern":"README.md","role":"repository_navigation"},
    {"pattern":"Cargo.toml","role":"build_manifest"},
    {"pattern":"Cargo.lock","role":"dependency_lock"},
    {"pattern":".gitignore","role":"version_control_policy"}
  ]
}
